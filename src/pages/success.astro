---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import settings from '../content/settings/main.json';
---

<BaseLayout title="Message Sent" description="Your message has been received.">
  <Header />

  <section class="success-page">
    <div class="container">
      <div class="success-card">
        <div class="success-icon">✓</div>
        <h1>Message Sent!</h1>
        <p>Thanks for reaching out. Ben will get back to you within one business day.</p>
        <p class="contact-direct">
          Need a faster response? Call directly:
          <a href={`tel:${settings.phone.replace(/\D/g,'')}`}>{settings.phone}</a>
        </p>
        <div class="success-actions">
          <a href="/" class="btn btn-primary">Back to Home</a>
          <a href="/services" class="btn btn-outline-dark">View Our Services</a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  .success-page {
    min-height: 70vh;
    display: flex;
    align-items: center;
    padding: 5rem 0;
    background: var(--off-white);
  }

  .success-card {
    max-width: 520px;
    margin: 0 auto;
    text-align: center;
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 3rem 2.5rem;
    box-shadow: var(--shadow-lg);
  }

  .success-icon {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--green);
    color: var(--white);
    font-size: 1.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.5rem;
  }

  .success-card h1 {
    font-size: 1.8rem;
    margin-bottom: 0.75rem;
  }

  .success-card p {
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }

  .contact-direct {
    font-size: 0.875rem;
    margin-top: 0.25rem;
    margin-bottom: 2rem !important;
  }

  .contact-direct a {
    color: var(--orange);
    font-weight: 600;
  }

  .success-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
