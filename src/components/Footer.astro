---
import settings from '../content/settings/main.json';
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <a href="/" class="footer-logo">
        <span class="logo-mark">TREAD</span>
        <span class="logo-sub">Timber Ridge Engineering & Design</span>
      </a>
      <p class="footer-tagline">Practical structural engineering and home design solutions for the Willamette Valley.</p>
      <p class="footer-service-area">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        {settings.serviceArea}
      </p>
    </div>

    <nav class="footer-nav" aria-label="Footer navigation">
      <h4>Navigation</h4>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/services">Services</a></li>
        <li><a href="/projects">Projects</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </nav>

    <div class="footer-contact">
      <h4>Get in Touch</h4>
      <ul>
        <li>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.72a16 16 0 0 0 6.29 6.29l.91-.85a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7a2 2 0 0 1 1.72 2.01z"/></svg>
          <a href={`tel:${settings.phone.replace(/\D/g,'')}`}>{settings.phone}</a>
        </li>
        <li>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          <a href={`mailto:${settings.email}`}>{settings.email}</a>
        </li>
        <li>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <span>{settings.address}</span>
        </li>
      </ul>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container">
      <p>&copy; {new Date().getFullYear()} Timber Ridge Engineering & Design, LLC. All rights reserved.</p>
      <p class="footer-license">{settings.credentials}</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--dark);
    color: rgba(255,255,255,0.7);
    margin-top: auto;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1.5fr;
    gap: 3rem;
    padding: 4rem 1.5rem 3rem;
  }

  .footer-logo {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    margin-bottom: 1rem;
    line-height: 1;
  }

  .footer-logo .logo-mark {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.4rem;
    font-weight: 800;
    color: var(--orange);
    letter-spacing: 0.05em;
  }

  .footer-logo .logo-sub {
    font-size: 0.58rem;
    font-weight: 500;
    color: rgba(255,255,255,0.4);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-top: 3px;
  }

  .footer-tagline {
    font-size: 0.875rem;
    line-height: 1.6;
    color: rgba(255,255,255,0.55);
    margin-bottom: 0.75rem;
  }

  .footer-service-area {
    display: flex;
    align-items: flex-start;
    gap: 0.4rem;
    font-size: 0.8rem;
    color: rgba(255,255,255,0.4);
    margin-bottom: 0;
  }

  .footer-service-area svg {
    flex-shrink: 0;
    margin-top: 3px;
    color: var(--green-light);
  }

  .footer-nav h4,
  .footer-contact h4 {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--orange-light);
    margin-bottom: 1.25rem;
  }

  .footer-nav ul,
  .footer-contact ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer-nav a {
    color: rgba(255,255,255,0.65);
    font-size: 0.9rem;
    text-decoration: none;
    transition: color 0.15s;
  }
  .footer-nav a:hover { color: var(--white); }

  .footer-contact li {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    font-size: 0.875rem;
    color: rgba(255,255,255,0.65);
  }

  .footer-contact svg {
    flex-shrink: 0;
    margin-top: 3px;
    color: var(--orange-light);
  }

  .footer-contact a {
    color: rgba(255,255,255,0.65);
    text-decoration: none;
    transition: color 0.15s;
  }
  .footer-contact a:hover { color: var(--white); }

  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.08);
  }

  .footer-bottom .container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding-top: 1.25rem;
    padding-bottom: 1.25rem;
  }

  .footer-bottom p {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.35);
    margin: 0;
  }

  .footer-license {
    color: rgba(255,255,255,0.25) !important;
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding: 2.5rem 1.5rem;
    }

    .footer-bottom .container {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
